                </svg>
            </div>
        </div>

    </section>

    <section class="article-comments">

        <div class="left-side">
            <h2>Laat je bericht achter</h2>

            <form action="/{{ district }}/{{ slug }}/comment/" method="post">
                <input type="hidden" name="story" value="{{ story.id }}">

                <label class="comments-field" for="name">
                    <span>Jouw naam *</span>
                    <input name="name" id="name" type="text" placeholder="Voornaam + achternaam " required>
                </label>

                <label class="comments-field" for="comment">
                    <span>Jouw bericht *</span>
                    <textarea name="comment" id="comment" rows="3" placeholder="Ik had een opmerking over..."
                        required></textarea>
                </label>

                <button class="primary-button" type="submit">Verzenden</button>
            </form>
        </div>
        <div class="right-side">
            <img src="/assets/buurtcampus_0012_pop-die-formulier-invult.png" alt="Formulier invullen">
        </div>
    </section>

    <section class="recent-comments">
        <h2>Recente reacties</h2>
        <div class="recent-comments-container">

            {% if story.comments.size > 0 %}
            {% for comment in story.comments limit:3 %}
            <article class="single-comment">
                <span class="comment-name">{{ comment.name }}</span>
                <p class="comment-text">{{ comment.comment }}</p>
            </article>
            {% endfor %}
            {% else %}
            <div class="empty-state">
                <span>Nog geen reacties</span>
            </div>
            {% endif %}

        </div>
    </section>

    <section class="featured-articles">
        <h2>Meer bekijken uit {{ district }}?</h2>


        <div class="district-articles {{ district }}">
            {% assign district_stories = stories | where: "district", district %}

            {% for story in district_stories limit:4 %}

            <a href="/{{ story.district }}/{{ story.slug }}" class="single-article-link">
                <article class="single-article {{ district }}">
                    {% if story.cover %}
                    <img class="article-cover" src="https://fdnd-agency.directus.app/assets/{{ story.cover }}" alt="">
                    {% else %}
                    <img class="article-cover fallback" src="/assets/Compact_Blurple_{{ district }}.png"
                        alt="Geen afbeelding beschikbaar">
                    {% endif %}

                    <div class="article-card-content">
                        <time class="article-date" datetime="{{ story.date }}">{{ story.date | date: "%d-%m-%Y"
                            }}</time>
                        <h3 class="article-title">{{ story.title }}</h3>
                    </div>
                </article>
            </a>

            {% endfor %}
        </div>

    </section>

</main>

{% render 'partials/foot.liquid' %}