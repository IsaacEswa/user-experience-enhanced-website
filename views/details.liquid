                    viewBox="0 0 512 512"><!--!Font Awesome Free 7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                    <path d="M0 256a256 256 0 1 1 512 0 256 256 0 1 1 -512 0z" />
                </svg>
                <span>{{ district | capitalize }}</span>
            </div>

            <h1 class="article-title">{{ story.title }}</h1>
            <p class="article-intro">{{ story.intro }}</p>
            <div class="article-body">{{ story.body }}</div>

            <div class="share-socials">
                <svg height="20" xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 448 512"><!--!Font Awesome Free 7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
