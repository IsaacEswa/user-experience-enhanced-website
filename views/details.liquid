{% render 'partials/head.liquid' %}

<main>

    <section class="details-container {{ district }}" style="background-color: var(--{{ district }});">

        <a class="back-link" href="/{{ district }}">← Terug naar overzicht</a>

        {% comment %} {% assign story = stories %} {% endcomment %}

        {% if story.cover %}
        <img class="single-article-cover" src="https://fdnd-agency.directus.app/assets/{{ story.cover }}" alt="">
        {% else %}
        <img class="single-article-cover fallback" src="/assets/Compact_Blurple_{{ district }}.png"
            alt="Geen afbeelding beschikbaar">
        {% endif %}

        <div class="article-content">
            <div class="article-information">
                <time class="article-date" datetime="{{ story.date }}">{{ story.date | date: "%d-%m-%Y" }}</time>
